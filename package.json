{
  "name": "react-example",
  "private": true,
  "description": "AeroMusic Premium Streamer",
  "author": "AeroMusic",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeromusic/premium.git"
  },
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=bundle --external:vite --outfile=dist-server/server.cjs",
    "bundle-server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=bundle --external:vite --outfile=dist-server/server.cjs",
    "electron:build": "npm run build && electron-builder build --win nsis && powershell -Command \"if (-not (Test-Path 'release')) { New-Item -ItemType Directory -Path 'release' | Out-Null }; Copy-Item 'dist-desktop/AeroMusicInstaller.exe' 'release/AeroMusicInstaller.exe' -Force; Remove-Item 'dist-desktop' -Recurse -Force\"",
    "electron:admin": "electron-builder build --config electron-builder-admin.json --win",
    "start": "node dist-server/server.cjs",
    "clean": "rm -rf dist dist-server dist-desktop server.js",
    "lint": "tsc --noEmit",
    "build:release": "powershell -ExecutionPolicy Bypass -File scripts\\build_release.ps1"
  },
  "build": {
    "appId": "com.aeromusic.premium",
    "productName": "AeroMusic",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "data/**/*",
      "tools/**/*",
      "electron-main.cjs",
      "electron-preload.cjs"
    ],
    "asar": true,
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "artifactName": "AeroMusicInstaller.exe",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@distube/ytdl-core": "^4.16.12",
    "@globules-io/cordova-plugin-background-mode": "^1.0.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "uuid": "^9.0.0",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "electron": "^36.9.5",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
